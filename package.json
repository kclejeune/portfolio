{
  "name": "portfolio",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kclejeune/portfolio.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm check && vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "vite dev",
    "preview": "vite preview",
    "format": "oxfmt --write .",
    "lint": "oxfmt --check . && eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "upgrade": "npm-check-updates -u && pnpm install"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.65.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^16.5.0",
    "npm-check-updates": "^22.2.3",
    "oxfmt": "^0.55.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-seo": "^2.0.0",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
